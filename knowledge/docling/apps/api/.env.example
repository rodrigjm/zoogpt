# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# OpenAI (required)
OPENAI_API_KEY=your-openai-api-key-here

# LLM Settings (ollama or openai)
LLM_PROVIDER=openai

# TTS Settings (kokoro or openai)
TTS_PROVIDER=openai
TTS_VOICE=af_heart
ELEVENLABS_API_KEY=your-elevenlabs-key-optional

# STT Settings (faster-whisper or openai)
STT_PROVIDER=openai

# RAG Settings
LANCEDB_PATH=data/zoo_lancedb
EMBEDDING_MODEL=text-embedding-3-small

# Session Settings
SESSION_DB_PATH=data/sessions.db

# CORS Settings (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
